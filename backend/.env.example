# Salin file ini menjadi .env dan isi dengan nilai asli kamu

# Google Sheets
SPREADSHEET_ID=your_spreadsheet_id_here

# Service Account - isi salah satu cara di bawah:

# Cara 1: path ke file JSON service account
GOOGLE_SERVICE_ACCOUNT_PATH=./service-account.json

# Cara 2: langsung paste JSON (untuk deploy di Railway/Render)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Server
PORT=3000
FRONTEND_URL=http://localhost:5173
